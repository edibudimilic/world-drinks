---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { drinkCountries, countryBySlug } from '../../data/drinks';

export function getStaticPaths() {
  return drinkCountries.map((country) => ({ params: { slug: country.slug } }));
}

const country = countryBySlug.get(Astro.params.slug ?? '');

if (!country) {
  return Astro.redirect('/');
}

const imageClassName = country.image.localPath?.endsWith('.svg') ? 'drink-image is-art' : 'drink-image';
---

<BaseLayout title={`${country.drink} in ${country.name} | World Drinks`} description={`${country.name}'s featured drink is ${country.drink}. ${country.description}`} image={country.image.localPath ?? '/icons/icon-512.png'}>
  <main class="country-page">
    <a class="back-link" href="/">Back to map</a>
    <section class="country-hero" aria-labelledby="country-title">
      <div>
        <p class="eyebrow">{country.flag} {country.name}</p>
        <h1 id="country-title">{country.drink}</h1>
        <p class="lede">{country.description}</p>
        <dl class="meta-grid">
          <div><dt>Region</dt><dd>{country.region}</dd></div>
          <div><dt>Type</dt><dd>{country.drinkType}</dd></div>
        </dl>
      </div>
      <div class="drink-image-wrap">
        {country.image.localPath ? (
          <img class={imageClassName} src={country.image.localPath} alt={`${country.drink} from ${country.name}`} />
        ) : (
          <div class="image-placeholder" role="img" aria-label={`${country.drink} illustration`}>
            <div><strong>{country.drink}</strong><span>A featured drink from {country.name}.</span></div>
          </div>
        )}
      </div>
    </section>
  </main>
</BaseLayout>